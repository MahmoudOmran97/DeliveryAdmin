@model DeliveryAdmin.Models.RestaurantDto
@{ViewData["Title"] = Model.Name; var categories = (List<DeliveryAdmin.Models.CategoryDto>)ViewBag.Categories;}

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;flex-wrap:wrap;gap:10px">
  <div style="display:flex;align-items:center;gap:14px">
    @if(!string.IsNullOrEmpty(Model.ImageUrl)){<img src="@Model.ImageUrl" style="width:60px;height:60px;border-radius:14px;object-fit:cover">}
    <div>
      <h2 style="font-size:20px;font-weight:800">@Model.Name</h2>
      <div class="text-muted text-sm">@Model.Address</div>
    </div>
  </div>
  <div style="display:flex;gap:8px">
    <a class="btn btn-secondary" href="/Restaurants/Edit/@Model.Id">✏️ Edit</a>
    <a class="btn btn-primary" href="/Categories/Index?restaurantId=@Model.Id">📂 Manage Menu</a>
    <a class="btn btn-secondary" href="/Products?restaurantId=@Model.Id">🍕 Products</a>
  </div>
</div>

<div class="detail-grid">
  <div class="detail-section">
    <div class="detail-section-title">Restaurant Info</div>
    <div class="detail-row"><span class="detail-key">Phone</span><span class="detail-val">@(Model.Phone??"-")</span></div>
    <div class="detail-row"><span class="detail-key">Status</span><span class="badge @(Model.IsOpen?"b-open":"b-closed")">@(Model.IsOpen?"Open":"Closed")</span></div>
    <div class="detail-row"><span class="detail-key">Rating</span><span class="detail-val">⭐ @Model.Rating.ToString("F1") (@Model.TotalRatings reviews)</span></div>
    <div class="detail-row"><span class="detail-key">Delivery Fee</span><span class="detail-val mono">@Model.DeliveryFee EGP</span></div>
    <div class="detail-row"><span class="detail-key">Min Order</span><span class="detail-val mono">@Model.MinOrderAmount EGP</span></div>
    <div class="detail-row"><span class="detail-key">Est. Time</span><span class="detail-val mono">@Model.EstimatedTime min</span></div>
    <div class="detail-row"><span class="detail-key">Created</span><span class="detail-val text-sm">@Model.CreatedAt.ToString("dd MMM yyyy")</span></div>
    @if(!string.IsNullOrEmpty(Model.Description)){<div style="margin-top:12px;font-size:13px;color:var(--text2)">@Model.Description</div>}
  </div>

  <div class="detail-section">
    <div class="detail-section-title">Categories (@categories.Count)</div>
    @if(!categories.Any()){<div class="empty"><div class="empty-icon">📂</div><div>No categories yet</div></div>}
    @foreach(var c in categories)
    {
      <div style="display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border)">
        <div>
          <div style="font-weight:600;font-size:13px">@c.Name</div>
          <div class="text-muted text-sm">@c.ProductCount products</div>
        </div>
        <div style="display:flex;gap:5px">
          <a class="btn btn-secondary btn-sm" href="/Categories/Edit/@c.Id">Edit</a>
          <form method="post" action="/Categories/Delete/@c.Id?restaurantId=@Model.Id">
            <button class="btn btn-danger btn-sm" onclick="return confirm('Delete category?')">Delete</button>
          </form>
        </div>
      </div>
    }
    <div style="margin-top:14px"><a class="btn btn-primary btn-sm" href="/Categories/Create?restaurantId=@Model.Id">+ Add Category</a></div>
  </div>
</div>
