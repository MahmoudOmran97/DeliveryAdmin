@using System.Globalization

@{
    var lang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isRtl = lang == "ar";
}

@model List<DeliveryAdmin.Models.DriverDto>

<div class="stat-row">
  <div class="stat-box"><div class="stat-label">@Localizer["Drivers_TotalDrivers"]</div><div class="stat-val">@ViewBag.TotalAll</div></div>
  <div class="stat-box"><div class="stat-label">@Localizer["Drivers_OnlineNow"]</div><div class="stat-val" style="color:var(--green)">@ViewBag.TotalOnline</div></div>
  <div class="stat-box"><div class="stat-label">@Localizer["Drivers_VerifiedCount"]</div><div class="stat-val" style="color:var(--blue)">@ViewBag.TotalVerified</div></div>
  <div class="stat-box"><div class="stat-label">@Localizer["Drivers_PendingVerify"]</div><div class="stat-val" style="color:var(--amber)">@ViewBag.TotalPending</div></div>
</div>

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px">
  @{var colors=new[]{"#f97316","#3b82f6","#22c55e","#a855f7","#f59e0b","#ef4444"};}
  @foreach(var (d,i) in Model.Take(6).Select((d,i)=>(d,i)))
  {
    <div class="card" style="padding:16px">
      <div style="display:flex;align-items:center;gap:11px;margin-bottom:12px">
        <div style="width:42px;height:42px;border-radius:50%;background:@colors[i%6]22;color:@colors[i%6];display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700">@(d.UserName?.FirstOrDefault().ToString().ToUpper()??"D")</div>
        <div>
          <div style="font-weight:700;font-size:13px">@(d.UserName??d.FullName??"Driver #"+d.Id)</div>
          <div class="text-muted text-sm">@d.VehicleType · @d.LicensePlate</div>
        </div>
        <span class="badge @(d.IsOnline?"b-online":"b-offline")" style="margin-left:auto">@(d.IsOnline?Localizer["Drivers_Online"].Value:Localizer["Drivers_Offline"].Value)</span>
      </div>
      <div style="display:flex;gap:16px;padding-top:10px;border-top:1px solid var(--border)">
        <div><div style="font-size:16px;font-weight:800">@d.TotalDeliveries</div><div class="text-muted" style="font-size:10px;text-transform:uppercase;font-weight:600">@Localizer["Drivers_Deliveries"]</div></div>
        <div><div style="font-size:16px;font-weight:800">@d.Rating.ToString("F1")</div><div class="text-muted" style="font-size:10px;text-transform:uppercase;font-weight:600">@Localizer["Drivers_Rating"]</div></div>
        <div><div style="font-size:16px;font-weight:800">@(d.IsVerified?"✓":"⏳")</div><div class="text-muted" style="font-size:10px;text-transform:uppercase;font-weight:600">@Localizer["Drivers_VerifiedCount"]</div></div>
      </div>
    </div>
  }
</div>

<div class="card">
  <div class="card-header">
    <div class="card-title">@Localizer["Drivers_AllDrivers"]</div>
    <div class="filters">
      <a class="btn btn-sm @(ViewBag.Filter==null?"btn-primary":"btn-secondary")" asp-action="Index">@Localizer["Users_All"]</a>
      <a class="btn btn-sm @(ViewBag.Filter=="online"?"btn-success":"btn-secondary")" asp-action="Index" asp-route-filter="online">@Localizer["Drivers_Online"]</a>
      <a class="btn btn-sm @(ViewBag.Filter=="offline"?"btn-secondary":"btn-secondary")" asp-action="Index" asp-route-filter="offline">@Localizer["Drivers_Offline"]</a>
      <a class="btn btn-sm @(ViewBag.Filter=="verified"?"btn-primary":"btn-secondary")" asp-action="Index" asp-route-filter="verified">@Localizer["Drivers_VerifiedCount"]</a>
      <a class="btn btn-sm @(ViewBag.Filter=="pending"?"btn-warning":"btn-secondary")" asp-action="Index" asp-route-filter="pending">@Localizer["Drivers_Pending"]</a>
    </div>
  </div>
  <div class="table-wrap">
    <table>
      <thead><tr><th>@Localizer["Nav_Drivers"]</th><th>@Localizer["Drivers_Vehicle"]</th><th>@Localizer["Drivers_License"]</th><th>@Localizer["Drivers_NationalId"]</th><th>@Localizer["Drivers_Rating"]</th><th>@Localizer["Drivers_Deliveries"]</th><th>@Localizer["Status"]</th><th>@Localizer["Drivers_VerifiedCount"]</th><th>@Localizer["Joined"]</th><th>@Localizer["Actions"]</th></tr></thead>
      <tbody>
        @if(!Model.Any()){<tr><td colspan="10"><div class="empty"><div class="empty-icon">🛵</div><div>@Localizer["Drivers_NoData"]</div></div></td></tr>}
        @foreach(var d in Model)
        {
          <tr>
            <td><div style="display:flex;align-items:center;gap:8px"><div style="width:32px;height:32px;border-radius:50%;background:var(--bg4);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--text2)">@(d.UserName?.FirstOrDefault().ToString().ToUpper()??"D")</div><div><div style="font-weight:600">@(d.UserName??d.FullName??"Driver #"+d.Id)</div><div class="text-muted text-sm">@d.Email</div></div></div></td>
            <td>@d.VehicleType</td>
            <td class="mono">@d.LicensePlate</td>
            <td class="mono text-muted">@(d.NationalId??"-")</td>
            <td><span class="stars">⭐</span> @d.Rating.ToString("F1")</td>
            <td class="mono">@d.TotalDeliveries</td>
            <td><span class="badge @(d.IsOnline?"b-online":"b-offline")">@(d.IsOnline?Localizer["Drivers_Online"].Value:Localizer["Drivers_Offline"].Value)</span></td>
            <td>@if(d.IsVerified){<span class="badge b-verified">@Localizer["Drivers_VerifiedCount"]</span>}else{<span class="badge b-pending">@Localizer["Drivers_Pending"]</span>}</td>
            <td class="text-muted text-sm">@d.JoinedAt.ToString("dd MMM yyyy")</td>
            <td>
              <div style="display:flex;gap:4px;flex-wrap:wrap">
                <a class="btn btn-secondary btn-sm" asp-action="Edit" asp-route-id="@d.Id">✏️ @Localizer["Edit"]</a>
                @if(!d.IsVerified){
                  <form method="post" asp-action="Verify" asp-route-id="@d.Id">
                    <button class="btn btn-success btn-sm" type="submit">✓ @Localizer["Drivers_Verify"]</button>
                  </form>
                }
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
