@model List<DeliveryAdmin.Models.CategoryDto>
@{
    var rest = ViewBag.Restaurant as DeliveryAdmin.Models.RestaurantDto;
    string search = ViewBag.Search ?? "";
}
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;flex-wrap:wrap;gap:10px">
  <div>
    <h2 style="font-size:18px;font-weight:800">📂 @rest?.Name — @Localizer["Cat_MenuCategories"]</h2>
    <div class="text-muted text-sm">@Localizer["Cat_ManageDesc"]</div>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap">
    <a class="btn btn-secondary" asp-controller="Restaurants" asp-action="Details" asp-route-id="@ViewBag.RestaurantId">@Localizer["Cat_BackToRestaurant"]</a>
    <a class="btn btn-secondary" asp-controller="Products" asp-action="Index" asp-route-restaurantId="@ViewBag.RestaurantId">@Localizer["Cat_AllProducts"]</a>
    <a class="btn btn-primary" asp-action="Create" asp-route-restaurantId="@ViewBag.RestaurantId">+ @Localizer["Cat_Add"]</a>
  </div>
</div>

<div class="card" style="margin-bottom:18px">
  <div class="card-body" style="padding:12px 16px">
    <form method="get" style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
      <input type="hidden" name="restaurantId" value="@ViewBag.RestaurantId" />
      <input class="filter-input" name="search" value="@search" placeholder="@Localizer["Cat_SearchPlaceholder"]" style="min-width:200px" />
      <button class="btn btn-secondary btn-sm" type="submit">@Localizer["Products_Search"]</button>
      @if (!string.IsNullOrEmpty(search))
      {
        <a class="btn btn-secondary btn-sm" asp-action="Index" asp-route-restaurantId="@ViewBag.RestaurantId">✕ @Localizer["Cancel"]</a>
      }
      <span class="text-muted text-sm" style="margin-inline-start:8px">@ViewBag.Total @Localizer["Total"]</span>
    </form>
  </div>
</div>

@if (!Model.Any())
{
  <div class="card">
    <div class="empty">
      <div class="empty-icon">📂</div>
      <div>@Localizer["Cat_NoData"]</div>
      <div style="margin-top:14px">
        <a class="btn btn-primary" asp-action="Create" asp-route-restaurantId="@ViewBag.RestaurantId">+ @Localizer["Cat_AddFirst"]</a>
      </div>
    </div>
  </div>
}
else
{
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px">
    @foreach (var c in Model)
    {
      <div class="card">
        <div style="padding:16px">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px">
            @if (!string.IsNullOrEmpty(c.ImageUrl))
            {
              <img src="@c.ImageUrl" style="width:44px;height:44px;border-radius:10px;object-fit:cover" alt="">
            }
            else
            {
              <div style="width:44px;height:44px;border-radius:10px;background:var(--bg4);display:flex;align-items:center;justify-content:center;font-size:20px">📂</div>
            }
            <div>
              <div style="font-weight:700;font-size:14px">@c.Name</div>
              <div class="text-muted text-sm">@Localizer["Cat_Sort"]: @c.SortOrder</div>
            </div>
          </div>
          <div style="display:flex;align-items:center;justify-content:space-between;padding-top:10px;border-top:1px solid var(--border)">
            <div>
              <div style="font-size:20px;font-weight:800">@c.ProductCount</div>
              <div class="text-muted" style="font-size:10px;text-transform:uppercase;font-weight:700">@Localizer["Cat_Products"]</div>
            </div>
            <div style="display:flex;gap:5px;flex-wrap:wrap">
              <a class="btn btn-secondary btn-sm" asp-action="Edit" asp-route-id="@c.Id">@Localizer["Edit"]</a>
              <a class="btn btn-secondary btn-sm" asp-controller="Products" asp-action="Index" asp-route-restaurantId="@ViewBag.RestaurantId">@Localizer["Products_Title"]</a>
              <form method="post" asp-action="Delete" asp-route-id="@c.Id" asp-route-restaurantId="@ViewBag.RestaurantId" onsubmit="return confirm('@Localizer["DeleteConfirm"] @c.Name?')">
                <button class="btn btn-danger btn-sm" type="submit">@Localizer["Delete"]</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}
