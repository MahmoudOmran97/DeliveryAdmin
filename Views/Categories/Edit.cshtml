@model DeliveryAdmin.Models.UpdateCategoryDto
<div style="max-width:500px">
  <div class="card">
    <div class="card-header">
      <div class="card-title">✏️ @Localizer["Cat_Edit"] — @ViewBag.CategoryName</div>
      <a class="btn btn-secondary btn-sm" asp-action="Index" asp-route-restaurantId="@ViewBag.RestaurantId">← @Localizer["Cancel"]</a>
    </div>
    <div class="card-body">
      @if (TempData["Error"] != null)
      {
        <div class="alert alert-danger" style="margin-bottom:14px">@TempData["Error"]</div>
      }
      <form method="post">
        <input type="hidden" name="restaurantId" value="@ViewBag.RestaurantId" />
        <div class="form-group">
          <label class="form-label">@Localizer["Cat_Name"] *</label>
          <input class="form-control" asp-for="Name" required />
        </div>
        <div class="form-group">
          <label class="form-label">@Localizer["Cat_ImageUrl"]</label>
          <input class="form-control" asp-for="ImageUrl" />
        </div>
        <div class="form-group">
          <label class="form-label">@Localizer["Cat_SortOrder"]</label>
          <input class="form-control" asp-for="SortOrder" type="number" />
        </div>
        <div style="display:flex;gap:8px;margin-top:8px">
          <button class="btn btn-primary" type="submit">@Localizer["Cat_SaveBtn"]</button>
          <a class="btn btn-secondary" asp-action="Index" asp-route-restaurantId="@ViewBag.RestaurantId">@Localizer["Cancel"]</a>
        </div>
      </form>
    </div>
  </div>
</div>
