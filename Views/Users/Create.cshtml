@model DeliveryAdmin.Models.CreateUserDto
@{ var restaurants = (List<DeliveryAdmin.Models.RestaurantDto>)ViewBag.Restaurants; }
<div class="card">
  <div class="card-header">
    <div class="card-title">@Localizer["Users_Add"]</div>
    <a class="btn btn-secondary btn-sm" asp-action="Index">← @Localizer["Cancel"]</a>
  </div>
  <div class="card-body">
    <form method="post">
      <div class="form-grid">
        <div class="form-group"><label class="form-label">@Localizer["FullName"]</label><input class="form-control" asp-for="FullName" required /></div>
        <div class="form-group"><label class="form-label">@Localizer["Email"]</label><input class="form-control" asp-for="Email" type="email" required /></div>
        <div class="form-group"><label class="form-label">@Localizer["Phone"]</label><input class="form-control" asp-for="Phone" required /></div>
        <div class="form-group"><label class="form-label">@Localizer["Password"]</label><input class="form-control" asp-for="Password" type="password" required /></div>
        <div class="form-group">
          <label class="form-label">@Localizer["Role"]</label>
          <select class="form-control" asp-for="Role" id="roleSelect">
            <option value="Restaurant">@Localizer["Users_RestaurantOwner"]</option>
            <option value="Customer">@Localizer["Users_Customers"]</option>
            <option value="Driver">@Localizer["Users_Drivers"]</option>
            <option value="Admin">@Localizer["Users_Admins"]</option>
          </select>
        </div>
        <div class="form-group" id="restaurantField">
          <label class="form-label">@Localizer["SelectRestaurant"]</label>
          <select class="form-control" asp-for="RestaurantId">
            <option value="">@Localizer["NoRestaurant"]</option>
            @foreach(var r in restaurants){<option value="@r.Id">@r.Name</option>}
          </select>
        </div>
        <div class="form-group form-full"><label class="form-label">@Localizer["Address"]</label><input class="form-control" asp-for="Address" /></div>
      </div>
      <div style="margin-top:16px;display:flex;gap:10px">
        <button type="submit" class="btn btn-primary">@Localizer["Save"]</button>
        <a class="btn btn-secondary" asp-action="Index">@Localizer["Cancel"]</a>
      </div>
    </form>
  </div>
</div>
@section Scripts{<script>document.getElementById('roleSelect')?.addEventListener('change',function(){document.getElementById('restaurantField').style.display=this.value==='Restaurant'?'block':'none';});document.getElementById('roleSelect')?.dispatchEvent(new Event('change'));</script>}
