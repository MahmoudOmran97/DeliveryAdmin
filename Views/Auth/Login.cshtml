@model LoginDto
@using System.Globalization

@{
    Layout = null;
    var lang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isRtl = lang == "ar";
}
<!DOCTYPE html>
<html lang="@lang" dir="@(isRtl ? "rtl" : "ltr")">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@Localizer["Login_Title"] — DeliveryApp Admin</title>
@if (isRtl) { <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet"> }
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0a0a0b;--bg2:#111113;--bg3:#18181c;--border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.12);--text:#f0f0f2;--text2:#8a8a96;--text3:#55555f;--accent:#f97316;--font:'Syne',sans-serif;--mono:'JetBrains Mono',monospace}
body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;display:flex;align-items:center;justify-content:center}
body.rtl-font{font-family:'Cairo',sans-serif}
.login-wrap{width:100%;max-width:400px;padding:20px}
.login-logo{text-align:center;margin-bottom:36px}
.logo-icon{width:56px;height:56px;background:var(--accent);border-radius:16px;display:inline-flex;align-items:center;justify-content:center;font-size:28px;margin-bottom:14px}
.logo-title{font-size:22px;font-weight:800;letter-spacing:-.5px}
.logo-sub{font-size:12px;color:var(--text3);font-family:var(--mono);margin-top:4px}
.login-card{background:var(--bg2);border:1px solid var(--border2);border-radius:18px;padding:30px}
.form-label{display:block;font-size:10px;color:var(--text3);font-weight:700;text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px}
.form-control{width:100%;background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:11px 14px;border-radius:10px;font-size:14px;outline:none;font-family:inherit;transition:border-color .15s;margin-bottom:16px}
.form-control:focus{border-color:var(--accent)}
.form-control::placeholder{color:var(--text3)}
.btn-login{width:100%;background:var(--accent);color:#fff;border:none;padding:12px;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;transition:opacity .15s;margin-top:4px}
.btn-login:hover{opacity:.9}
.error{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:#ef4444;padding:11px 14px;border-radius:10px;font-size:13px;margin-bottom:16px}
.hint{font-size:11px;color:var(--text3);text-align:center;margin-top:16px;font-family:var(--mono)}
.lang-row{display:flex;justify-content:center;gap:8px;margin-bottom:16px}
.lang-row select{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:6px 10px;border-radius:8px;font-size:12px}
</style>
</head>
<body class="@(isRtl ? "rtl-font" : "")">
<div class="login-wrap">
  <div class="login-logo">
    <div class="logo-icon">🚀</div>
    <div class="logo-title">DeliveryApp</div>
    <div class="logo-sub">@Localizer["Login_AdminDashboard"]</div>
  </div>
  <div class="login-card">
    <form asp-controller="Settings" asp-action="SetLanguage" method="post" class="lang-row">
      <input type="hidden" name="returnUrl" value="/Auth/Login" />
      <select name="culture" onchange="this.form.submit()">
        @if (lang == "en") { <option value="en" selected>@Localizer["Lang_English"]</option> } else { <option value="en">@Localizer["Lang_English"]</option> }
        @if (lang == "ar") { <option value="ar" selected>@Localizer["Lang_Arabic"]</option> } else { <option value="ar">@Localizer["Lang_Arabic"]</option> }
      </select>
    </form>
    @if(ViewBag.Error != null){<div class="error">❌ @ViewBag.Error</div>}
    <form method="post">
      <label class="form-label">@Localizer["Email"]</label>
      <input class="form-control" asp-for="Email" type="email" placeholder="admin@example.com" required>
      <label class="form-label">@Localizer["Password"]</label>
      <input class="form-control" asp-for="Password" type="password" placeholder="••••••••" required>
      <button class="btn-login" type="submit">@Localizer["Login_Button"] →</button>
    </form>
    <div class="hint">API: deliveryappapi.runasp.net</div>
  </div>
</div>
</body>
</html>
