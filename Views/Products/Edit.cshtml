@model DeliveryAdmin.Models.CreateProductDto
@{
    ViewData["Title"] = "Edit: " + ViewBag.ProductName;
}
<div style="max-width:700px">
    <div class="card">
        <div class="card-header"><div class="card-title">✏️ Edit Product</div><a class="btn btn-secondary btn-sm" href="/Products">← Back</a></div>
        <div class="card-body">
            <form method="post" id="productForm">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Restaurant</label>
                        <select class="form-control" id="restSelect" onchange="loadCategories(this.value)">
                            <option value="">Select Restaurant…</option>
                            @foreach (var r in (List<DeliveryAdmin.Models.RestaurantDto>)ViewBag.Restaurants)
                            {
                                <option value="@r.Id">@r.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Category *</label>
                        <select class="form-control" name="CategoryId" id="catSelect" required>
                            <option value="">Select category…</option>
                        </select>
                    </div>
                    <div class="form-group form-full"><label class="form-label">Name *</label><input class="form-control" asp-for="Name" required></div>
                    <div class="form-group form-full"><label class="form-label">Description</label><textarea class="form-control" asp-for="Description"></textarea></div>
                    <div class="form-group"><label class="form-label">Price (EGP) *</label><input class="form-control" asp-for="Price" type="number" step="0.01" required></div>
                    <div class="form-group"><label class="form-label">Discounted Price</label><input class="form-control" asp-for="DiscountedPrice" type="number" step="0.01"></div>
                    <div class="form-group"><label class="form-label">Prep Time (min)</label><input class="form-control" asp-for="PreparationTime" type="number"></div>
                    <div class="form-group"><label class="form-label">Calories</label><input class="form-control" asp-for="Calories" type="number"></div>
                    <div class="form-group form-full"><label class="form-label">Image URL</label><input class="form-control" asp-for="ImageUrl"></div>
                    <div class="form-group form-full">
                        <label class="form-label">📏 Sizes / Options (optional) — e.g. Small/Medium/Large, or Strip/Box</label>
                        <div id="variantsList"></div>
                        <button type="button" class="btn btn-secondary btn-sm" onclick="addVariantRow()" style="margin-top:6px">+ Add Option</button>
                        <input type="hidden" name="variantsJson" id="variantsJson">
                        <div id="variantsWarning" style="display:none;color:#dc3545;margin-top:6px;font-size:.85rem"></div>
                    </div>
                </div>
                <div style="display:flex;gap:8px;margin-top:8px">
                    <button class="btn btn-primary" type="submit" id="saveBtn">💾 Save Changes</button>
                    <a class="btn btn-secondary" href="/Products">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        let variantRowCount = 0;

        function addVariantRow(name = '', price = '') {
          const list = document.getElementById('variantsList');
          const rowId = 'vrow_' + (variantRowCount++);
          const row = document.createElement('div');
          row.id = rowId;
          row.dataset.rowMarker = '1'; // used to reliably count real variant rows, independent of DOM structure
          row.style = 'display:flex;gap:8px;margin-top:6px;align-items:center';
          row.innerHTML = `
            <input class="form-control vname" placeholder="e.g. Large / علبة" value="${name}" style="flex:2">
            <input class="form-control vprice" type="number" step="0.01" placeholder="Price (EGP)" value="${price}" style="flex:1">
            <button type="button" class="btn btn-secondary btn-sm" onclick="document.getElementById('${rowId}').remove()">✕</button>
          `;
          list.appendChild(row);
        }

        // Accepts "15", "15.00", or "15,00" (Arabic/European style decimal comma) safely.
        function parsePrice(raw) {
          if (raw === null || raw === undefined) return NaN;
          const normalized = String(raw).trim().replace(',', '.');
          return parseFloat(normalized);
        }

        // Returns the collected variants, or null if collection could not be trusted
        // (e.g. a row is missing an input, which would otherwise silently produce
        // an empty array and wipe out every existing variant on the server).
        function collectVariants() {
          const rows = document.querySelectorAll('#variantsList > div[data-row-marker]');
          const variants = [];
          const problems = [];

          rows.forEach((row, i) => {
            const nameInput = row.querySelector('.vname');
            const priceInput = row.querySelector('.vprice');

            if (!nameInput || !priceInput) {
              // Structural problem — do not silently continue, this would drop a row.
              problems.push(`Row ${i + 1}: missing input fields`);
              return;
            }

            const name = nameInput.value.trim();
            const priceRaw = priceInput.value;
            const price = parsePrice(priceRaw);

            // If the row is completely empty, the user hasn't filled it in — skip silently.
            if (!name && !priceRaw) return;

            // If the row is partially filled, that's a real data problem — flag it instead
            // of silently dropping the variant.
            if (!name || isNaN(price)) {
              problems.push(`Row ${i + 1}: "${name || '(no name)'}" needs both a name and a valid price`);
              return;
            }

            variants.push({ name: name, price: price, sortOrder: i });
          });

          return { variants, problems, totalRows: rows.length };
        }

        function handleSubmit(e) {
          const { variants, problems, totalRows } = collectVariants();
          const warningEl = document.getElementById('variantsWarning');

          if (problems.length > 0) {
            // Block the submit entirely — better to stop the user than to silently
            // save an incomplete/empty variants list and erase existing options.
            e.preventDefault();
            warningEl.style.display = 'block';
            warningEl.textContent = '⚠️ Fix these options before saving: ' + problems.join(' | ');
            console.error('Variant collection problems:', problems);
            return;
          }

          // Sanity check: if there were rows on screen but we ended up with zero
          // variants, something is wrong with collection — don't submit blindly.
          if (totalRows > 0 && variants.length === 0) {
            e.preventDefault();
            warningEl.style.display = 'block';
            warningEl.textContent = '⚠️ Could not read the options you entered — please check them and try again.';
            console.error('collectVariants produced an empty list despite', totalRows, 'rows being present.');
            return;
          }

          warningEl.style.display = 'none';
          document.getElementById('variantsJson').value = JSON.stringify(variants);
        }

        document.getElementById('productForm').addEventListener('submit', handleSubmit);

        const existingVariants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    ((List<DeliveryAdmin.Models.ProductVariantDto>)ViewBag.Variants),
                    new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
    existingVariants.forEach(v => addVariantRow(v.name, v.price));

        async function loadCategories(restaurantId) {
          const sel = document.getElementById('catSelect');
          if (!restaurantId) return;
          const res = await fetch('/Products/GetCategoriesJson?restaurantId=' + restaurantId);
          const cats = await res.json();
          sel.innerHTML = '<option value="">Select category…</option>' + cats.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
        }
    </script>
}